  "keyFeatures": [
    "Natural language goal parsing using AI (Google Gemini)",
    "Real-time banking data integration via Capital One Nessie and Plaid APIs",
    "Parallel Monte Carlo simulation engine (100k runs in ~500ms)",
    "Sensitivity analysis and what-if scenario modeling",
    "Voice narration of results via ElevenLabs",
    "Interactive 3D visualizations with Three.js and Recharts",
    "Account-aware simulation with per-card/loan modeling",
    "Income growth, inflation, and emergency event modeling"
  ],
  "publicApiSurface": [
    "POST /api/simulation/financial-profile - Get aggregated financial profile from banking data",
    "POST /api/simulation/simulate - Run Monte Carlo simulation with custom parameters",
    "POST /api/simulation/sensitivity - Run sensitivity analysis on financial parameters",
    "POST /api/simulation/simulate-enhanced - Run simulation with Plaid-enhanced parameters",
    "POST /api/llm/parse-goal - Parse natural language goal into structured target",
    "POST /api/llm/recommendations - Generate AI-powered recommendations",
    "GET /api/nessie/customers - Fetch customer data from Nessie API",
    "GET /api/nessie/accounts/:customerId - Get customer accounts",
    "POST /api/plaid/create-link-token - Create Plaid Link token",
    "POST /api/plaid/exchange-token - Exchange Plaid public token",
    "python3 simulation/main.py --mode simulate - Run simulation engine via CLI",
    "python3 simulation/main.py --mode sensitivity - Run sensitivity analysis via CLI",
    "run_monte_carlo() - Core Python Monte Carlo engine function",
    "run_sensitivity_analysis() - Python sensitivity analysis function"
  ]
